@model Gestion_EDT.Models.Groupe
@{
    ViewData["Title"] = "Nouveau Groupe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="form-card-title">Créer un nouveau groupe</div>
                <div class="form-card-sub">Renseignez les informations du groupe</div>
            </div>
        </div>
        <div class="form-card-body">
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>
                <div class="form-group mb-3">
                    <label asp-for="nom_groupe" class="form-label">Nom du groupe *</label>
                    <input asp-for="nom_groupe" class="form-control" id="nom_groupe" required />
                    <span asp-validation-for="nom_groupe" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="code_groupe" class="form-label">Code groupe *</label>
                    <input asp-for="code_groupe" class="form-control" id="code_groupe" required />
                    <span asp-validation-for="code_groupe" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="nb_etudiant" class="form-label">Effectif *</label>
                    <input asp-for="nb_etudiant" type="number" class="form-control" id="nb_etudiant" required />
                    <span asp-validation-for="nb_etudiant" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ParcoursId" class="form-label">Parcours *</label>
                    <select asp-for="ParcoursId" class="form-control" id="ParcoursId" asp-items="ViewBag.ParcoursId" required>
                        <option value="">— Choisir —</option>
                    </select>
                    <span asp-validation-for="ParcoursId" class="text-danger"></span>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn-primary-emit" id="btnSubmit"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSubmit').addEventListener('click', function() {
            const nom = document.getElementById('nom_groupe').value.trim();
            const code = document.getElementById('code_groupe').value.trim();
            const effectif = parseInt(document.getElementById('nb_etudiant').value);
            const parcoursId = parseInt(document.getElementById('ParcoursId').value);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!nom || !code || !effectif || !parcoursId) {
                window.showToast('Tous les champs sont obligatoires.', 'warning');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('nom_groupe', nom);
            formData.append('code_groupe', code);
            formData.append('nb_etudiant', effectif);
            formData.append('ParcoursId', parcoursId);

            fetch('/Groupes/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(async r => {
                if (r.ok) {
                    window.showToast('Groupe créé avec succès.', 'success');
                    setTimeout(() => window.location.href = '/Groupes', 800);
                } else {
                    try {
                        const data = await r.json();
                        if (data.errors) {
                            window.showToast(data.errors.join('\n'), 'error');
                        } else {
                            window.showToast('Erreur lors de la création.', 'error');
                        }
                    } catch {
                        window.showToast('Erreur inconnue.', 'error');
                    }
                }
            })
            .catch(err => window.showToast('Erreur réseau.', 'error'));
        });
    </script>
}