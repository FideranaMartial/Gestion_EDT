@{
    ViewData["Title"] = "Nouvelle séance";
    ViewData["ActivePage"] = "Seance";
}

<div class="seance-create-page">

    <!-- En-tête -->
    <div class="page-header-emit mb-4">
        <div class="page-header-left">
            <a href="/Planning" class="btn-back" title="Retour au planning">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="page-icon-wrap accent-calendar">
                <i class="bi bi-calendar-plus-fill"></i>
            </div>
            <div>
                <h1 class="page-title-emit">Nouvelle séance</h1>
                <p class="page-subtitle-emit">Planifiez une séance de cours dans l'emploi du temps</p>
            </div>
        </div>
    </div>

    <div class="create-layout">

        <!-- Formulaire principal -->
        <div class="form-col">
            <div class="card-emit form-card">

                <div id="conflitAlert" class="conflit-alert" style="display:none;">
                    <div class="conflit-alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="conflit-alert-body">
                        <strong id="conflitTitle">Conflit détecté</strong>
                        <p id="conflitMessage" class="mb-0"></p>
                    </div>
                </div>

                <div id="checkingIndicator" class="checking-indicator" style="display:none;">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    <span>Vérification des conflits en cours…</span>
                </div>

                <form id="seanceForm" novalidate>

                    <!-- Ligne 1 : Date + Libellé -->
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="date">Date <span class="required-star">*</span></label>
                            <input type="date" id="date" name="date" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-date"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="libelle">Libellé <span class="required-star">*</span></label>
                            <input type="text" id="libelle" name="libelle" class="emit-input" placeholder="ex. Algorithmique — Cours magistral" required autocomplete="off" />
                            <div class="field-error" id="error-libelle"></div>
                        </div>
                    </div>

                    <!-- Ligne 2 : Heure début + Heure fin -->
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="heureDebut">Heure de début <span class="required-star">*</span></label>
                            <input type="time" id="heureDebut" name="heureDebut" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-heureDebut"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="heureFin">Heure de fin <span class="required-star">*</span></label>
                            <input type="time" id="heureFin" name="heureFin" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-heureFin"></div>
                        </div>
                    </div>

                    <!-- Ligne 3 : Groupe + Matière -->
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="groupeId">Groupe <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="groupeId" name="GroupeId" class="emit-select" required>
                                    <option value="">— Chargement… —</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-groupeId"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="matiereId">Matière <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="matiereId" name="MatiereId" class="emit-select" required>
                                    <option value="">— Chargement… —</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-matiereId"></div>
                        </div>
                    </div>

                    <!-- Ligne 4 : Salle + Enseignant -->
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="salleId">Salle <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="salleId" name="SalleId" class="emit-select" required>
                                    <option value="">— Chargement… —</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-salleId"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="enseignantId">Enseignant <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="enseignantId" name="EnseignantId" class="emit-select" required>
                                    <option value="">— Chargement… —</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-enseignantId"></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="form-actions">
                        <a href="/Planning" class="btn-emit-ghost"><i class="bi bi-x-lg me-2"></i>Annuler</a>
                        <button type="button" id="btnSubmit" class="btn-emit-primary" onclick="handleSubmit()">
                            <i class="bi bi-check-lg me-2"></i>Créer la séance
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <!-- Panneau d'aide -->
        <div class="info-col">
            <div class="card-emit info-card">
                <div class="info-card-header"><i class="bi bi-info-circle-fill me-2"></i>Rappels</div>
                <ul class="info-list">
                    <li><i class="bi bi-clock-fill"></i><span>Créneaux de <strong>7h30</strong> à <strong>18h30</strong>.</span></li>
                    <li><i class="bi bi-exclamation-circle-fill" style="color:var(--warning);"></i><span>Conflit automatique (salle/enseignant/groupe).</span></li>
                    <li><i class="bi bi-calendar-check-fill" style="color:var(--success);"></i><span>Dimanche exclu.</span></li>
                    <li><i class="bi bi-shield-check-fill" style="color:var(--accent);"></i><span>Soumission bloquée en cas de conflit.</span></li>
                </ul>
            </div>

            <div class="card-emit recap-card" id="recapCard" style="display:none;">
                <div class="info-card-header"><i class="bi bi-clipboard-check-fill me-2"></i>Récapitulatif</div>
                <div class="recap-grid">
                    <div class="recap-row"><span class="recap-label">Date</span><span class="recap-value" id="recapDate">—</span></div>
                    <div class="recap-row"><span class="recap-label">Horaire</span><span class="recap-value" id="recapHoraire">—</span></div>
                    <div class="recap-row"><span class="recap-label">Groupe</span><span class="recap-value" id="recapGroupe">—</span></div>
                    <div class="recap-row"><span class="recap-label">Matière</span><span class="recap-value" id="recapMatiere">—</span></div>
                    <div class="recap-row"><span class="recap-label">Salle</span><span class="recap-value" id="recapSalle">—</span></div>
                    <div class="recap-row"><span class="recap-label">Enseignant</span><span class="recap-value" id="recapEnseignant">—</span></div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════════
     Styles spécifiques à Seance/Create
═══════════════════════════════════════════════ -->
<style>
    .seance-create-page { padding: 1.5rem; }

    /* ── En-tête ── */
    .page-header-emit {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .page-header-left { display: flex; align-items: center; gap: 0.9rem; }
    .btn-back {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: rgba(115,185,230,0.1);
        border: 1px solid rgba(115,185,230,0.2);
        color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
        text-decoration: none;
        transition: var(--transition);
        flex-shrink: 0;
    }
    .btn-back:hover { background: var(--accent); color: var(--bg-primary); }
    .page-icon-wrap {
        width: 48px; height: 48px;
        border-radius: var(--radius);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .accent-calendar {
        background: linear-gradient(135deg, #34D399, #059669);
        color: #fff;
        box-shadow: 0 4px 12px rgba(52,211,153,0.35);
    }
    .page-title-emit { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin: 0; }
    .page-subtitle-emit { font-size: 0.82rem; color: var(--text-muted); margin: 0; margin-top: 2px; }

    /* ── Layout deux colonnes ── */
    .create-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.5rem;
        align-items: start;
    }
    @@media (max-width: 992px) {
        .create-layout { grid-template-columns: 1fr; }
        .info-col { order: -1; }
    }

    /* ── Carte formulaire ── */
    .form-card { padding: 1.75rem 2rem; }

    /* ── Alerte conflit ── */
    .conflit-alert {
        display: flex;
        gap: 0.9rem;
        align-items: flex-start;
        background: rgba(248,113,113,0.12);
        border: 1px solid rgba(248,113,113,0.4);
        border-left: 4px solid var(--danger);
        border-radius: 10px;
        padding: 1rem 1.2rem;
        margin-bottom: 1.5rem;
        animation: slideDown 0.25s ease;
    }
    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .conflit-alert-icon { font-size: 1.3rem; color: var(--danger); flex-shrink: 0; padding-top: 1px; }
    .conflit-alert-body { flex: 1; }
    .conflit-alert-body strong { color: var(--danger); font-size: 0.9rem; display: block; margin-bottom: 2px; }
    .conflit-alert-body p { color: #FCA5A5; font-size: 0.85rem; }

    /* ── Indicateur vérification ── */
    .checking-indicator {
        display: flex;
        align-items: center;
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
        padding: 0.5rem 0.75rem;
        background: rgba(115,185,230,0.08);
        border-radius: 8px;
        animation: pulse-opacity 1s ease-in-out infinite;
    }
    @@keyframes pulse-opacity { 0%,100%{opacity:1} 50%{opacity:0.6} }

    /* ── Grilles de champs ── */
    .form-row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem 1.5rem;
        margin-bottom: 1.25rem;
    }
    @@media (max-width: 576px) {
        .form-row-2 { grid-template-columns: 1fr; }
        .form-card { padding: 1.25rem; }
    }
    .field-group { display: flex; flex-direction: column; gap: 6px; }
    .field-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .required-star { color: var(--danger); }

    /* ── Inputs ── */
    .emit-input {
        background: rgba(23,37,84,0.6);
        border: 1px solid rgba(115,185,230,0.2);
        border-radius: 8px;
        color: var(--text-primary);
        font-family: var(--font-main);
        font-size: 0.88rem;
        padding: 0.6rem 0.85rem;
        transition: var(--transition);
        outline: none;
        width: 100%;
    }
    .emit-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(115,185,230,0.15);
    }
    .emit-input.is-invalid { border-color: var(--danger); }
    .emit-input.is-valid { border-color: var(--success); }
    .emit-input::-webkit-calendar-picker-indicator { filter: invert(0.6) sepia(1) saturate(5) hue-rotate(175deg); }

    /* ── Selects ── */
    .select-wrapper { position: relative; }
    .emit-select {
        width: 100%;
        background: rgba(23,37,84,0.6);
        border: 1px solid rgba(115,185,230,0.2);
        border-radius: 8px;
        color: var(--text-primary);
        font-family: var(--font-main);
        font-size: 0.88rem;
        padding: 0.6rem 2.2rem 0.6rem 0.85rem;
        appearance: none;
        -webkit-appearance: none;
        cursor: pointer;
        transition: var(--transition);
        outline: none;
    }
    .emit-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(115,185,230,0.15); }
    .emit-select.is-invalid { border-color: var(--danger); }
    .emit-select option { background: #1F4E79; color: var(--text-primary); }
    .select-arrow {
        position: absolute; right: 0.7rem; top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted); font-size: 0.75rem; pointer-events: none;
    }

    /* ── Erreurs champs ── */
    .field-error {
        font-size: 0.76rem;
        color: var(--danger);
        min-height: 1.1em;
        display: none;
    }
    .field-error.visible { display: block; }

    /* ── Actions ── */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        margin-top: 1.75rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(115,185,230,0.1);
    }
    .btn-emit-ghost {
        display: inline-flex; align-items: center;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        border: 1px solid rgba(115,185,230,0.3);
        color: var(--text-muted);
        font-family: var(--font-main);
        font-size: 0.88rem;
        font-weight: 500;
        text-decoration: none;
        transition: var(--transition);
    }
    .btn-emit-ghost:hover { border-color: var(--accent); color: var(--accent); background: rgba(115,185,230,0.08); }

    /* ── Carte info latérale ── */
    .info-card, .recap-card { padding: 1.25rem 1.4rem; margin-bottom: 1rem; }
    .info-card-header {
        font-size: 0.82rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text-muted);
        display: flex; align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px solid rgba(115,185,230,0.1);
    }
    .info-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
    .info-list li { display: flex; gap: 0.7rem; align-items: flex-start; }
    .info-list li i { font-size: 0.95rem; color: var(--text-muted); flex-shrink: 0; margin-top: 1px; }
    .info-list li span { font-size: 0.82rem; color: var(--text-muted); line-height: 1.4; }
    .info-list li strong { color: var(--text-primary); }

    /* ── Récap ── */
    .recap-grid { display: flex; flex-direction: column; gap: 0.6rem; }
    .recap-row { display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }
    .recap-label { font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center; white-space: nowrap; }
    .recap-value { font-size: 0.82rem; color: var(--text-primary); font-weight: 500; text-align: right; }
</style>

@section Scripts {
<script>
(function () {
    'use strict';

    let hasConflit = false;
    let sallesData = [];
    let groupesData = [];
    let matieresData = [];

    const form = document.getElementById('seanceForm');
    const btnSubmit = document.getElementById('btnSubmit');
    const conflitAlert = document.getElementById('conflitAlert');
    const conflitTitle = document.getElementById('conflitTitle');
    const conflitMsg = document.getElementById('conflitMessage');
    const checkingInd = document.getElementById('checkingIndicator');
    const recapCard = document.getElementById('recapCard');

    function debounce(fn, delay) {
        let timer;
        return function (...args) {
            clearTimeout(timer);
            timer = setTimeout(() => fn.apply(this, args), delay);
        };
    }

    // ── Chargement des salles ──
    async function loadSalles() {
        const sel = document.getElementById('salleId');
        try {
            const response = await fetch('/Seances/GetSalles');
            if (!response.ok) throw new Error('Erreur chargement');
            const list = await response.json();
            sallesData = list;
            sel.innerHTML = '<option value="">— Choisir une salle —</option>';
            list.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id;
                opt.textContent = `${s.nom} (Capacité: ${s.capacite})`;
                opt.dataset.capacite = s.capacite;
                sel.appendChild(opt);
            });
        } catch {
            sel.innerHTML = '<option value="">— Choisir une salle —</option>';
            window.showToast('Impossible de charger les salles.', 'warning');
        }
    }

    // ── Chargement des groupes ──
    async function loadGroupes() {
        const sel = document.getElementById('groupeId');
        try {
            const response = await fetch('/Seances/GetGroupes');
            if (!response.ok) throw new Error('Erreur chargement');
            const list = await response.json();
            groupesData = list;
            sel.innerHTML = '<option value="">— Choisir un groupe —</option>';
            list.sort((a, b) => a.nom.localeCompare(b.nom));
            list.forEach(g => {
                const opt = document.createElement('option');
                opt.value = g.id;
                opt.textContent = `${g.nom} (${g.nbEtudiant} étudiants)`;
                opt.dataset.nbEtudiant = g.nbEtudiant;
                sel.appendChild(opt);
            });
        } catch {
            sel.innerHTML = '<option value="">— Choisir un groupe —</option>';
            window.showToast('Impossible de charger les groupes.', 'warning');
        }
    }

        // ── Chargement des matières (toutes) ──
        async function loadMatieres() {
            const sel = document.getElementById('matiereId');
            try {
                const response = await fetch('/Seances/GetMatieres');
                if (!response.ok) throw new Error('Erreur chargement');
                const list = await response.json();
                sel.innerHTML = '<option value="">— Choisir une matière —</option>';
                list.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.textContent = m.intitule;
                    sel.appendChild(opt);
                });
            } catch {
                sel.innerHTML = '<option value="">— Choisir une matière —</option>';
                window.showToast('Impossible de charger les matières.', 'warning');
            }
        }

        // ── Chargement des matières par groupe ──
        async function loadMatieresByGroupe(groupeId) {
            if (!groupeId) {
                // Si aucun groupe sélectionné, charger toutes les matières
                await loadMatieres();
                return;
            }
            const sel = document.getElementById('matiereId');
            try {
                const response = await fetch(`/Seances/GetMatieresByGroupe?groupeId=${groupeId}`);
                if (!response.ok) throw new Error('Erreur chargement');
                const list = await response.json();
                sel.innerHTML = '<option value="">— Choisir une matière —</option>';
                list.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.textContent = m.intitule;
                    sel.appendChild(opt);
                });
            } catch {
                sel.innerHTML = '<option value="">— Choisir une matière —</option>';
                window.showToast('Impossible de charger les matières pour ce groupe.', 'warning');
            }
        }

    // ── Chargement des enseignants ──
    async function loadEnseignants() {
        const sel = document.getElementById('enseignantId');
        try {
            const response = await fetch('/Seances/GetEnseignants');
            if (!response.ok) throw new Error('Erreur chargement');
            const list = await response.json();
            sel.innerHTML = '<option value="">— Choisir un enseignant —</option>';
            list.forEach(e => {
                const opt = document.createElement('option');
                opt.value = e.id;
                opt.textContent = `${e.prenom} ${e.nom}`;
                sel.appendChild(opt);
            });
        } catch {
            sel.innerHTML = '<option value="">Erreur de chargement</option>';
            window.showToast('Impossible de charger les enseignants.', 'error');
        }
    }

    // ── Vérification de capacité ──
    function verifierCapacite() {
        const salleId = document.getElementById('salleId').value;
        const groupeId = document.getElementById('groupeId').value;
        if (!salleId || !groupeId) return true;

        const salle = sallesData.find(s => s.id == salleId);
        const groupe = groupesData.find(g => g.id == groupeId);
        if (!salle || !groupe) return true;

        if (groupe.nbEtudiant > salle.capacite) {
            window.showToast(
                `⚠ La salle "${salle.nom}" a une capacité de ${salle.capacite} places, mais le groupe "${groupe.nom}" compte ${groupe.nbEtudiant} étudiants.`,
                'warning'
            );
            return false;
        }
        return true;
    }

    // ── Construction du payload de vérification conflit ──
    function buildConflitPayload() {
        const date = document.getElementById('date').value;
        const debut = document.getElementById('heureDebut').value;
        const fin = document.getElementById('heureFin').value;
        const salleId = document.getElementById('salleId').value;
        const enseignantId = document.getElementById('enseignantId').value;
        const groupeId = document.getElementById('groupeId').value;

        if (!date || !debut || !fin || !salleId || !enseignantId || !groupeId) return null;

        const params = new URLSearchParams({
            date: date,
            heureDebut: debut,
            heureFin: fin,
            salleId: salleId,
            enseignantId: enseignantId,
            groupeId: groupeId
        });
        return params;
    }

    function showConflitAlert(message, type) {
        hasConflit = true;
        const typeLabel = {
            salle: 'Conflit de salle',
            prof: 'Conflit enseignant',
            groupe: 'Conflit de groupe',
        }[type] || 'Conflit détecté';
        conflitTitle.textContent = typeLabel;
        conflitMsg.textContent = message;
        conflitAlert.style.display = 'flex';
        btnSubmit.disabled = true;
        btnSubmit.style.opacity = '0.5';
    }

    function hideConflitAlert() {
        hasConflit = false;
        conflitAlert.style.display = 'none';
        btnSubmit.disabled = false;
        btnSubmit.style.opacity = '';
    }

    const checkConflit = debounce(async function () {
        const params = buildConflitPayload();
        if (!params) {
            hideConflitAlert();
            return;
        }

        checkingInd.style.display = 'flex';
        try {
            const response = await fetch('/Seances/CheckConflit?' + params.toString());
            if (!response.ok) throw new Error('Erreur vérification');
            const result = await response.json();
            if (result.hasConflit) {
                showConflitAlert(result.message, result.type);
            } else {
                hideConflitAlert();
            }
        } catch (err) {
            console.error(err);
            hideConflitAlert();
        } finally {
            checkingInd.style.display = 'none';
        }
    }, 500);

    // ── Mise à jour du récapitulatif ──
    function updateRecap() {
        const date = document.getElementById('date').value;
        const debut = document.getElementById('heureDebut').value;
        const fin = document.getElementById('heureFin').value;
        const salleId = document.getElementById('salleId').value;
        const enseignantId = document.getElementById('enseignantId').value;
        const groupeId = document.getElementById('groupeId').value;
        const matiereId = document.getElementById('matiereId').value;

        const salleLabel = salleId ? (document.getElementById('salleId').options[document.getElementById('salleId').selectedIndex]?.textContent || '—') : '—';
        const enseignantLabel = enseignantId ? (document.getElementById('enseignantId').options[document.getElementById('enseignantId').selectedIndex]?.textContent || '—') : '—';
        const groupeLabel = groupeId ? (document.getElementById('groupeId').options[document.getElementById('groupeId').selectedIndex]?.textContent || '—') : '—';
        const matiereLabel = matiereId ? (document.getElementById('matiereId').options[document.getElementById('matiereId').selectedIndex]?.textContent || '—') : '—';

        const anyFilled = date || debut || fin || salleId || enseignantId || groupeId || matiereId;
        recapCard.style.display = anyFilled ? 'block' : 'none';

        document.getElementById('recapDate').textContent =
            date ? new Date(date + 'T00:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' }) : '—';
        document.getElementById('recapHoraire').textContent =
            (debut && fin) ? `${debut} → ${fin}` : (debut || '—');
        document.getElementById('recapGroupe').textContent = groupeLabel;
        document.getElementById('recapMatiere').textContent = matiereLabel;
        document.getElementById('recapSalle').textContent = salleLabel;
        document.getElementById('recapEnseignant').textContent = enseignantLabel !== '— Choisir un enseignant —' ? enseignantLabel : '—';
    }

    // ── Écouteurs ──
    ['date', 'heureDebut', 'heureFin', 'salleId', 'enseignantId', 'groupeId', 'matiereId'].forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('change', () => {
            updateRecap();
            checkConflit();
            // Vérification de capacité après changement de salle ou groupe
            if (id === 'salleId' || id === 'groupeId') {
                verifierCapacite();
            }
        });
        if (el.tagName === 'INPUT') {
            el.addEventListener('input', () => {
                updateRecap();
                checkConflit();
            });
        }

        // écouteur spécifique pour groupeId
        document.getElementById('groupeId').addEventListener('change', function () {
            const groupeId = this.value;
            loadMatieresByGroupe(groupeId);
        });
    });

    // ── Soumission ──
    window.handleSubmit = async function () {
        if (window.ValidationEngine && !window.ValidationEngine.validateForm(form).valid) {
            window.showToast('Veuillez corriger les erreurs du formulaire.', 'warning');
            return;
        }
        if (hasConflit) {
            window.showToast('Impossible de créer la séance : un conflit a été détecté.', 'error');
            return;
        }
        if (!verifierCapacite()) {
            window.showToast('Capacité de la salle insuffisante pour ce groupe.', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('date_seance', document.getElementById('date').value);
        formData.append('heure_debut', document.getElementById('heureDebut').value);
        formData.append('heure_fin', document.getElementById('heureFin').value);
        formData.append('MatiereId', document.getElementById('matiereId').value);
        formData.append('GroupeId', document.getElementById('groupeId').value);
        formData.append('SalleId', document.getElementById('salleId').value);
        formData.append('EnseignantId', document.getElementById('enseignantId').value);

        // Calcul de la semaine
        const dateVal = document.getElementById('date').value;
        if (dateVal) {
            const dateObj = new Date(dateVal + 'T00:00:00');
            const weekNumber = getISOWeek(dateObj);
            formData.append('semaine', weekNumber);
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!token) {
            window.showToast('Token CSRF manquant.', 'error');
            return;
        }

        try {
            btnSubmit.disabled = true;
            btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Création...';

            const response = await fetch('/Seances/Create', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });

            const text = await response.text();
            console.log("Réponse brute:", text);

            if (response.ok) {
                window.showToast('Séance créée avec succès !', 'success');
                setTimeout(() => { window.location.href = '/Planning'; }, 900);
            } else {
                const text = await response.text();
                let errorMsg = 'Une erreur est survenue.';
                try {
                    const json = JSON.parse(text);
                    if (json.message) errorMsg = json.message;
                } catch {
                    if (text.includes('Conflit')) errorMsg = text;
                }
                window.showToast(errorMsg, 'error');
            }
        } catch (err) {
            window.showToast('Erreur réseau. Veuillez réessayer.', 'error');
            console.error(err);
        } finally {
            btnSubmit.disabled = false;
            btnSubmit.innerHTML = '<i class="bi bi-check-lg me-2"></i>Créer la séance';
        }
    };

    // ── Fonction ISO week ──
    function getISOWeek(date) {
        const d = new Date(date);
        d.setHours(0, 0, 0, 0);
        const thursday = new Date(d);
        thursday.setDate(d.getDate() + (3 - (d.getDay() + 6) % 7));
        const firstThursday = new Date(thursday.getFullYear(), 0, 4);
        return 1 + Math.round(((thursday - firstThursday) / 86400000 - 3 + (firstThursday.getDay() + 6) % 7) / 7);
    }

    // ── Initialisation ──
    document.addEventListener('DOMContentLoaded', function () {
        loadSalles();
        loadGroupes();
        loadMatieres();
        loadEnseignants();
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('date').min = today;
        updateRecap();
    });

})();
</script>
}