@{
    ViewData["Title"] = "Nouvelle séance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="seance-create-page">
    <div class="page-header-emit mb-4">
        <div class="page-header-left">
            <a href="/Planning" class="btn-back" title="Retour au planning"><i class="bi bi-arrow-left"></i></a>
            <div class="page-icon-wrap accent-calendar"><i class="bi bi-calendar-plus-fill"></i></div>
            <div>
                <h1 class="page-title-emit">Nouvelle séance</h1>
                <p class="page-subtitle-emit">Planifiez une séance de cours dans l'emploi du temps</p>
            </div>
        </div>
    </div>

    <div class="create-layout">
        <div class="form-col">
            <div class="card-emit form-card">
                <div id="conflitAlert" class="conflit-alert" style="display:none;">
                    <div class="conflit-alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="conflit-alert-body">
                        <strong id="conflitTitle">Conflit détecté</strong>
                        <p id="conflitMessage"></p>
                    </div>
                </div>
                <div id="checkingIndicator" class="checking-indicator" style="display:none;">
                    <div class="spinner-border spinner-border-sm me-2"></div> Vérification des conflits...
                </div>

                <form id="seanceForm" novalidate>
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="date">Date <span class="required-star">*</span></label>
                            <input type="date" id="date" name="date" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-date"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="libelle">Libellé de la séance <span class="required-star">*</span></label>
                            <input type="text" id="libelle" name="libelle" class="emit-input" placeholder="ex. Algorithmique — Cours magistral" required autocomplete="off" />
                            <div class="field-error" id="error-libelle"></div>
                        </div>
                    </div>
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="heureDebut">Heure de début <span class="required-star">*</span></label>
                            <input type="time" id="heureDebut" name="heureDebut" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-heureDebut"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="heureFin">Heure de fin <span class="required-star">*</span></label>
                            <input type="time" id="heureFin" name="heureFin" class="emit-input" required autocomplete="off" />
                            <div class="field-error" id="error-heureFin"></div>
                        </div>
                    </div>
                    <div class="form-row-2">
                        <div class="field-group">
                            <label class="field-label" for="salleId">Salle <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="salleId" name="salleId" class="emit-select" required>
                                    <option value="">— Choisir une salle —</option>
                                    <option value="1">Salle A101</option>
                                    <option value="2">Salle A102</option>
                                    <option value="3">Labo Informatique</option>
                                    <option value="4">Amphi 200</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-salleId"></div>
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="enseignantId">Enseignant <span class="required-star">*</span></label>
                            <div class="select-wrapper">
                                <select id="enseignantId" name="enseignantId" class="emit-select" required>
                                    <option value="">— Chargement —</option>
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                            <div class="field-error" id="error-enseignantId"></div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <a href="/Planning" class="btn-emit-ghost"><i class="bi bi-x-lg me-2"></i>Annuler</a>
                        <button type="button" id="btnSubmit" class="btn-emit-primary" onclick="handleSubmit()">
                            <i class="bi bi-check-lg me-2"></i>Créer la séance
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="info-col">
            <div class="card-emit info-card">
                <div class="info-card-header"><i class="bi bi-info-circle-fill me-2"></i>Rappels</div>
                <ul class="info-list">
                    <li><i class="bi bi-clock-fill"></i><span>Créneaux de 7h30 à 18h30.</span></li>
                    <li><i class="bi bi-exclamation-circle-fill" style="color:var(--warning);"></i><span>Un conflit (salle/enseignant déjà pris) bloquera la création.</span></li>
                    <li><i class="bi bi-calendar-check-fill" style="color:var(--success);"></i><span>Le dimanche est exclu.</span></li>
                </ul>
            </div>
            <div class="card-emit recap-card" id="recapCard" style="display:none;">
                <div class="info-card-header"><i class="bi bi-clipboard-check-fill me-2"></i>Récapitulatif</div>
                <div class="recap-grid">
                    <div class="recap-row"><span class="recap-label">Date</span><span class="recap-value" id="recapDate">—</span></div>
                    <div class="recap-row"><span class="recap-label">Horaire</span><span class="recap-value" id="recapHoraire">—</span></div>
                    <div class="recap-row"><span class="recap-label">Salle</span><span class="recap-value" id="recapSalle">—</span></div>
                    <div class="recap-row"><span class="recap-label">Enseignant</span><span class="recap-value" id="recapEnseignant">—</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styles (inchangés, déjà présents dans votre fichier) */
    .seance-create-page { padding: 1.5rem; }
    .page-header-emit { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .page-header-left { display: flex; align-items: center; gap: 0.9rem; }
    .btn-back { width: 40px; height: 40px; border-radius: 10px; background: rgba(115,185,230,0.1); border: 1px solid rgba(115,185,230,0.2); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; text-decoration: none; transition: var(--transition); flex-shrink: 0; }
    .btn-back:hover { background: var(--accent); color: var(--bg-primary); }
    .page-icon-wrap { width: 48px; height: 48px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .accent-calendar { background: linear-gradient(135deg, #34D399, #059669); color: #fff; box-shadow: 0 4px 12px rgba(52,211,153,0.35); }
    .page-title-emit { font-size: 1.4rem; font-weight: 700; margin: 0; }
    .page-subtitle-emit { font-size: 0.82rem; color: var(--text-muted); margin-top: 2px; }
    .create-layout { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items: start; }
    @@media (max-width: 992px) { .create-layout { grid-template-columns: 1fr; } .info-col { order: -1; } }
    .form-card { padding: 1.75rem 2rem; }
    .conflit-alert { display: flex; gap: 0.9rem; background: rgba(248,113,113,0.12); border-left: 4px solid var(--danger); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; animation: slideDown 0.25s ease; }
    .checking-indicator { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 1rem; padding: 0.5rem 0.75rem; background: rgba(115,185,230,0.08); border-radius: 8px; }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.5rem; margin-bottom: 1.25rem; }
    @@media (max-width: 576px) { .form-row-2 { grid-template-columns: 1fr; } }
    .field-group { display: flex; flex-direction: column; gap: 6px; }
    .field-label { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; }
    .required-star { color: var(--danger); }
    .emit-input, .emit-select { background: rgba(23,37,84,0.6); border: 1px solid rgba(115,185,230,0.2); border-radius: 8px; color: var(--text-primary); font-size: 0.88rem; padding: 0.6rem 0.85rem; transition: var(--transition); outline: none; width: 100%; }
    .emit-input:focus, .emit-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(115,185,230,0.15); }
    .field-error { font-size: 0.76rem; color: var(--danger); display: none; }
    .field-error.visible { display: block; }
    .form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid rgba(115,185,230,0.1); }
    .btn-emit-ghost { display: inline-flex; align-items: center; padding: 0.6rem 1.2rem; border-radius: 8px; border: 1px solid rgba(115,185,230,0.3); color: var(--text-muted); transition: var(--transition); text-decoration: none; }
    .btn-emit-ghost:hover { border-color: var(--accent); color: var(--accent); background: rgba(115,185,230,0.08); }
    .info-card, .recap-card { padding: 1.25rem 1.4rem; margin-bottom: 1rem; }
    .info-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .info-list li { display: flex; gap: 0.7rem; align-items: flex-start; font-size: 0.82rem; color: var(--text-muted); }
    .recap-grid { display: flex; flex-direction: column; gap: 0.6rem; }
    .recap-row { display: flex; justify-content: space-between; align-items: center; }
    .recap-label { font-size: 0.78rem; color: var(--text-muted); }
    .recap-value { font-size: 0.82rem; color: var(--text-primary); font-weight: 500; text-align: right; }
</style>

@section Scripts {
<script>
    (function() {
        'use strict';

        const salleLabels = { '1': 'Salle A101', '2': 'Salle A102', '3': 'Labo Informatique', '4': 'Amphi 200' };
        let hasConflit = false;

        // Charger les enseignants
        async function loadEnseignants() {
            const sel = document.getElementById('enseignantId');
            try {
                const list = await window.MockAPI.getEnseignants();
                sel.innerHTML = '<option value="">— Choisir un enseignant —</option>';
                list.forEach(e => {
                    const opt = document.createElement('option');
                    opt.value = e.id;
                    opt.textContent = `${e.prenom} ${e.nom}`;
                    sel.appendChild(opt);
                });
            } catch {
                sel.innerHTML = '<option value="">Erreur de chargement</option>';
                window.showToast('Impossible de charger les enseignants.', 'error');
            }
        }

        // Mettre à jour le récapitulatif
        function updateRecap() {
            const date = document.getElementById('date').value;
            const heureDebut = document.getElementById('heureDebut').value;
            const heureFin = document.getElementById('heureFin').value;
            const salleId = document.getElementById('salleId').value;
            const enseignantId = document.getElementById('enseignantId').value;
            const enseignantText = enseignantId
                ? document.getElementById('enseignantId').options[document.getElementById('enseignantId').selectedIndex]?.textContent
                : null;

            const anyFilled = date || heureDebut || heureFin || salleId || enseignantId;
            document.getElementById('recapCard').style.display = anyFilled ? 'block' : 'none';

            document.getElementById('recapDate').textContent = date
                ? new Date(date + 'T00:00:00').toLocaleDateString('fr-FR', { weekday:'short', day:'numeric', month:'long' })
                : '—';
            document.getElementById('recapHoraire').textContent = (heureDebut && heureFin) ? `${heureDebut} → ${heureFin}` : (heureDebut || '—');
            document.getElementById('recapSalle').textContent = salleLabels[salleId] || '—';
            document.getElementById('recapEnseignant').textContent = (enseignantText && enseignantText !== '— Choisir un enseignant —') ? enseignantText : '—';
        }

        // Vérification de conflit simplifiée (MockAPI.checkConflit)
        let checkTimeout = null;
        function checkConflit() {
            clearTimeout(checkTimeout);
            checkTimeout = setTimeout(async () => {
                const date = document.getElementById('date').value;
                const heureDebut = document.getElementById('heureDebut').value;
                const heureFin = document.getElementById('heureFin').value;
                const salleId = document.getElementById('salleId').value;
                const enseignantId = document.getElementById('enseignantId').value;

                if (!date || !heureDebut || !heureFin || !salleId || !enseignantId) {
                    document.getElementById('conflitAlert').style.display = 'none';
                    hasConflit = false;
                    document.getElementById('btnSubmit').disabled = false;
                    return;
                }

                document.getElementById('checkingIndicator').style.display = 'flex';
                try {
                    const result = await window.MockAPI.checkConflit({
                        date, heureDebut, heureFin,
                        salleId: parseInt(salleId, 10),
                        enseignantId: parseInt(enseignantId, 10)
                    });
                    if (result.hasConflit) {
                        hasConflit = true;
                        const alertDiv = document.getElementById('conflitAlert');
                        alertDiv.style.display = 'flex';
                        document.getElementById('conflitMessage').innerText = result.message || 'Conflit détecté avec un autre créneau.';
                        document.getElementById('btnSubmit').disabled = true;
                    } else {
                        hasConflit = false;
                        document.getElementById('conflitAlert').style.display = 'none';
                        document.getElementById('btnSubmit').disabled = false;
                    }
                } catch (err) {
                    console.error(err);
                } finally {
                    document.getElementById('checkingIndicator').style.display = 'none';
                }
            }, 500);
        }

        // Soumission du formulaire
        window.handleSubmit = async function() {
            if (hasConflit) {
                window.showToast('Impossible de créer la séance : un conflit a été détecté.', 'error');
                return;
            }

            const libelle = document.getElementById('libelle').value.trim();
            const date = document.getElementById('date').value;
            const heureDebut = document.getElementById('heureDebut').value;
            const heureFin = document.getElementById('heureFin').value;
            const salleId = document.getElementById('salleId').value;
            const enseignantId = document.getElementById('enseignantId').value;

            if (!libelle || !date || !heureDebut || !heureFin || !salleId || !enseignantId) {
                window.showToast('Veuillez remplir tous les champs obligatoires.', 'warning');
                return;
            }

            const btn = document.getElementById('btnSubmit');
            try {
                const result = await window.fetchWithSpinner(btn, window.MockAPI.createSeance({
                    libelle, date, heureDebut, heureFin,
                    salleId: parseInt(salleId, 10),
                    enseignantId: parseInt(enseignantId, 10)
                }));
                if (result && result.id) {
                    window.showToast('Séance créée avec succès !', 'success');
                    setTimeout(() => window.location.href = '/Planning', 1000);
                } else {
                    window.showToast('Erreur lors de la création', 'error');
                }
            } catch (err) {
                window.handleApiError(err, 'createSeance');
            }
        };

        // Initialisation des écouteurs
        function bindEvents() {
            ['date', 'heureDebut', 'heureFin', 'salleId', 'enseignantId'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', () => { updateRecap(); checkConflit(); });
            });
            document.getElementById('date').addEventListener('input', updateRecap);
            document.getElementById('heureDebut').addEventListener('input', updateRecap);
            document.getElementById('heureFin').addEventListener('input', updateRecap);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadEnseignants();
            bindEvents();
            // Date minimale = aujourd'hui
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('date').min = today;
            updateRecap();
        });
    })();
</script>
}