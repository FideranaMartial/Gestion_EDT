@model Gestion_EDT.Models.Parcours
@{
    ViewData["Title"] = "Nouveau Parcours";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-diagram-3-fill"></i></div>
            <div>
                <div class="form-card-title">Créer un nouveau parcours</div>
                <div class="form-card-sub">Renseignez les informations du parcours</div>
            </div>
        </div>
        <div class="form-card-body">
            <form id="createForm" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>
                <div class="form-group mb-3">
                    <label asp-for="nom_parcours" class="form-label">Nom du parcours *</label>
                    <input asp-for="nom_parcours" class="form-control" id="nom_parcours" required />
                    <span asp-validation-for="nom_parcours" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CycleId" class="form-label">Cycle *</label>
                    <select asp-for="CycleId" class="form-control" id="CycleId" asp-items="ViewBag.CycleId" required>
                        <option value="">— Choisir —</option>
                    </select>
                    <span asp-validation-for="CycleId" class="text-danger"></span>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn-primary-emit" id="btnSubmit">Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSubmit').addEventListener('click', function() {
            const nom = document.getElementById('nom_parcours').value.trim();
            const cycleId = document.getElementById('CycleId').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!nom || !cycleId) {
                window.showToast('Tous les champs sont obligatoires.', 'warning');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('nom_parcours', nom);
            formData.append('CycleId', cycleId);

            fetch('/Parcours/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(async r => {
                if (r.ok) {
                    window.showToast('Parcours créé avec succès.', 'success');
                    setTimeout(() => window.location.href = '/Parcours', 800);
                } else {
                    try {
                        const data = await r.json();
                        if (data.errors) {
                            window.showToast(data.errors.join('\n'), 'error');
                        } else {
                            window.showToast('Erreur lors de la création.', 'error');
                        }
                    } catch {
                        window.showToast('Erreur inconnue.', 'error');
                    }
                }
            })
        });
    </script>
}