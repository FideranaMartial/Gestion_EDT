@model Gestion_EDT.Models.ChangePasswordFormModel
@{
    ViewData["Title"] = "Changer mon mot de passe";
}

<h2 class="mb-3">Changer mon mot de passe</h2>

@if (ViewData["Success"] != null)
{
    <div class="alert alert-success">@ViewData["Success"]</div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="ChangePassword" method="post" class="row g-3" style="max-width:420px">
    @Html.AntiForgeryToken()

    <div class="col-12">
        <label asp-for="CurrentPassword" class="form-label"></label>
        <input asp-for="CurrentPassword" type="password" class="form-control" />
        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" type="password" class="form-control" />
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Mettre à jour</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
