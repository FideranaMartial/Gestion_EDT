@model Gestion_EDT.Models.Salle
@{
    ViewData["Title"] = "Nouvelle Salle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-door-open-fill"></i></div>
            <div>
                <div class="form-card-title">Créer une nouvelle salle</div>
                <div class="form-card-sub">Renseignez les informations de la salle</div>
            </div>
        </div>
        <div class="form-card-body">
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>
                <div class="form-group mb-3">
                    <label asp-for="num_salle" class="form-label">Numéro de salle *</label>
                    <input asp-for="num_salle" class="form-control" id="num_salle" required />
                    <span asp-validation-for="num_salle" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="capacite" class="form-label">Capacité *</label>
                    <input asp-for="capacite" type="number" class="form-control" id="capacite" required />
                    <span asp-validation-for="capacite" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="BatimentId" class="form-label">Bâtiment *</label>
                    <select asp-for="BatimentId" class="form-control" id="BatimentId" asp-items="ViewBag.BatimentId" required>
                        <option value="">— Choisir —</option>
                    </select>
                    <span asp-validation-for="BatimentId" class="text-danger"></span>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn-primary-emit" id="btnSubmit"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSubmit').addEventListener('click', function() {
            const num = document.getElementById('num_salle').value.trim();
            const capacite = parseInt(document.getElementById('capacite').value);
            const batimentId = parseInt(document.getElementById('BatimentId').value);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!num || !capacite || !batimentId) {
                window.showToast('Tous les champs sont obligatoires.', 'warning');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('num_salle', num);
            formData.append('capacite', capacite);
            formData.append('BatimentId', batimentId);

            fetch('/Salles/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(async r => {
                if (r.ok) {
                    window.showToast('Salle créée avec succès.', 'success');
                    setTimeout(() => window.location.href = '/Salles', 800);
                } else {
                    try {
                        const data = await r.json();
                        if (data.errors) {
                            window.showToast(data.errors.join('\n'), 'error');
                        } else {
                            window.showToast('Erreur lors de la création.', 'error');
                        }
                    } catch {
                        window.showToast('Erreur inconnue.', 'error');
                    }
                }
            })
            .catch(err => window.showToast('Erreur réseau.', 'error'));
        });
    </script>
}