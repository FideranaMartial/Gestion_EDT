@* 

*@
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
/* DASHBOARD GRID LAYOUT  */
.dashboard-root {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 28px;
}

/*  KPI GRID */
.kpi-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr 1fr 0.9fr;
    gap: 18px;
    align-items: start;
}

/* Carte #1 légèrement plus grande */
.kpi-card:nth-child(1) {
    grid-row: span 1;
}

/* KPI SKELETON */
.kpi-skeleton {
    background: linear-gradient(145deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%);
    border: 1px solid rgba(115,185,230,0.08);
    border-radius: var(--radius);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 112px;
}

.skeleton-line {
    border-radius: 4px;
    height: 12px;
}
.skeleton-line.w-40  { width: 40%; }
.skeleton-line.w-55  { width: 55%; }
.skeleton-line.w-30  { width: 30%; }
.skeleton-line.h-32  { height: 32px; }
.skeleton-line.h-10  { height: 10px; }

/* CHART + RECENT GRID */
.bottom-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 20px;
    align-items: start;
}

/* CHART CARD */
.chart-card {
    background: linear-gradient(145deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%);
    border: 1px solid rgba(115,185,230,0.12);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: 24px 24px 20px;
}

.chart-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 22px;
    gap: 12px;
}

.chart-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 3px;
}

.chart-subtitle {
    font-size: 12px;
    color: var(--text-muted);
}

.chart-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    color: var(--success);
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    border-radius: 20px;
    padding: 4px 10px;
    white-space: nowrap;
}

.chart-wrap {
    position: relative;
    height: 220px;
}

.chart-skeleton {
    height: 220px;
    display: flex;
    align-items: flex-end;
    gap: 14px;
    padding: 0 4px;
}

.chart-bar-skel {
    flex: 1;
    border-radius: 6px 6px 0 0;
}

/*  RECENT MENTIONS CARD */
.recent-card {
    background: linear-gradient(145deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%);
    border: 1px solid rgba(115,185,230,0.12);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: 24px;
}

.recent-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
}

.recent-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
}

.recent-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.recent-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    background: rgba(23,37,84,0.4);
    border-radius: 10px;
    border: 1px solid rgba(115,185,230,0.07);
    transition: var(--transition);
    text-decoration: none;
}

.recent-item:hover {
    background: rgba(115,185,230,0.08);
    border-color: rgba(115,185,230,0.18);
    transform: translateX(3px);
}

.recent-item-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
}

.recent-item-icon.master   { background: rgba(167,139,250,0.15); color: #A78BFA; }
.recent-item-icon.licence  { background: rgba(115,185,230,0.15); color: var(--accent); }
.recent-item-icon.doctorat { background: rgba(251,191,36,0.15);  color: var(--warning); }

.recent-item-info {
    flex: 1;
    min-width: 0;
}

.recent-item-nom {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.recent-item-niveau {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 1px;
}

/* ─── ACTIVITY STRIP ─── */
.activity-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.activity-item {
    background: linear-gradient(145deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%);
    border: 1px solid rgba(115,185,230,0.1);
    border-radius: var(--radius);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: var(--transition);
}

.activity-item:hover {
    border-color: rgba(115,185,230,0.22);
    transform: translateY(-1px);
}

.activity-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}

.activity-text h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
}

.activity-text p {
    font-size: 12px;
    color: var(--text-muted);
}

/* SECTION HEADER */
.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
}

.section-heading {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
}

.section-sub {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 2px;
}

/* RESPONSIVE */
@@media (max-width: 1200px) {
    .kpi-grid {
        grid-template-columns: 1fr 1fr;
    }
    .bottom-grid {
        grid-template-columns: 1fr;
    }
}

@@media (max-width: 640px) {
    .kpi-grid {
        grid-template-columns: 1fr;
    }
    .activity-strip {
        grid-template-columns: 1fr;
    }
}
</style>
}

<div class="dashboard-root animate-fadein">

    @* En-tête page  *@
    <div class="section-header" style="margin-bottom:0;">
        <div>
            <h1 class="section-heading">Tableau de bord</h1>
            <p class="section-sub">Vue d'ensemble de l'activité — semaine en cours</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <span id="last-update" style="font-size:12px;color:var(--text-muted);">
                <i class="bi bi-clock" style="margin-right:4px;"></i>
                <span id="update-time">—</span>
            </span>
            <button class="btn-secondary-emit" id="btn-refresh" type="button" title="Rafraîchir les données">
                <i class="bi bi-arrow-clockwise"></i>
                Actualiser
            </button>
        </div>
    </div>

    @* SECTION 1 — KPI CARDS *@
    <section aria-label="Indicateurs clés">
        <div class="kpi-grid" id="kpi-grid">

            @* Skeleton loaders affichés avant le chargement *@
            <div class="kpi-skeleton" id="kpi-skel-1">
                <div class="skeleton skeleton-line w-55 h-10"></div>
                <div class="skeleton skeleton-line w-30 h-32"></div>
                <div class="skeleton skeleton-line w-40 h-10"></div>
            </div>
            <div class="kpi-skeleton" id="kpi-skel-2">
                <div class="skeleton skeleton-line w-55 h-10"></div>
                <div class="skeleton skeleton-line w-30 h-32"></div>
                <div class="skeleton skeleton-line w-40 h-10"></div>
            </div>
            <div class="kpi-skeleton" id="kpi-skel-3">
                <div class="skeleton skeleton-line w-55 h-10"></div>
                <div class="skeleton skeleton-line w-30 h-32"></div>
                <div class="skeleton skeleton-line w-40 h-10"></div>
            </div>
            <div class="kpi-skeleton" id="kpi-skel-4">
                <div class="skeleton skeleton-line w-55 h-10"></div>
                <div class="skeleton skeleton-line w-30 h-32"></div>
                <div class="skeleton skeleton-line w-40 h-10"></div>
            </div>

        </div>
    </section>

    @*SECTION 2 — CHART + RECENT MENTIONS *@
    <section aria-label="Graphique et mentions récentes">
        <div class="bottom-grid">

            @*  Chart.js — Séances par jour *@
            <div class="chart-card">
                <div class="chart-header">
                    <div>
                        <div class="chart-title">Séances par jour de la semaine</div>
                        <div class="chart-subtitle">Distribution hebdomadaire des créneaux planifiés</div>
                    </div>
                    <span class="chart-badge" id="chart-badge" style="display:none;">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span id="chart-total">—</span> séances
                    </span>
                </div>

                @* Skeleton chart *@
                <div class="chart-skeleton" id="chart-skeleton">
                    <div class="skeleton chart-bar-skel" style="height:55%;"></div>
                    <div class="skeleton chart-bar-skel" style="height:78%;"></div>
                    <div class="skeleton chart-bar-skel" style="height:42%;"></div>
                    <div class="skeleton chart-bar-skel" style="height:68%;"></div>
                    <div class="skeleton chart-bar-skel" style="height:35%;"></div>
                </div>

                <div class="chart-wrap" style="display:none;" id="chart-wrap">
                    <canvas id="seancesChart" aria-label="Graphique des séances par jour" role="img"></canvas>
                </div>
            </div>

            @* Mentions récentes *@
            <div class="recent-card">
                <div class="recent-header">
                    <div class="recent-title">Mentions récentes</div>
                    <a href="/Mentions" class="btn-icon-emit" title="Voir toutes les mentions">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                @* Skeleton *@
                <div id="mentions-skeleton" class="recent-list">
                    <div class="kpi-skeleton" style="min-height:56px;padding:12px 14px;">
                        <div class="skeleton skeleton-line w-55 h-10"></div>
                        <div class="skeleton skeleton-line w-40" style="height:8px;"></div>
                    </div>
                    <div class="kpi-skeleton" style="min-height:56px;padding:12px 14px;">
                        <div class="skeleton skeleton-line w-40 h-10"></div>
                        <div class="skeleton skeleton-line w-55" style="height:8px;"></div>
                    </div>
                    <div class="kpi-skeleton" style="min-height:56px;padding:12px 14px;">
                        <div class="skeleton skeleton-line w-55 h-10"></div>
                        <div class="skeleton skeleton-line w-30" style="height:8px;"></div>
                    </div>
                </div>

                <div id="mentions-list" class="recent-list" style="display:none;" role="list" aria-label="Liste des mentions récentes">
                </div>
            </div>

        </div>
    </section>

    @* SECTION 3 — ACTIVITÉ RAPIDE*@
    <section aria-label="Accès rapides">
        <div class="activity-strip">

            <div class="activity-item">
                <div class="activity-icon" style="background:rgba(115,185,230,0.12);color:var(--accent);">
                    <i class="bi bi-plus-circle-fill"></i>
                </div>
                <div class="activity-text">
                    <h4>Nouvelle séance</h4>
                    <p>Planifier un cours ou TP</p>
                </div>
                <a href="/Seances/Create" class="btn-icon-emit" style="margin-left:auto;" title="Créer une séance">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="activity-item">
                <div class="activity-icon" style="background:rgba(52,211,153,0.12);color:var(--success);">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <div class="activity-text">
                    <h4>Ajouter une mention</h4>
                    <p>Créer un nouveau parcours</p>
                </div>
                <a href="/Mention/Create" class="btn-icon-emit" style="margin-left:auto;" title="Créer une mention">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="activity-item">
                <div class="activity-icon" style="background:rgba(251,191,36,0.12);color:var(--warning);">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="activity-text">
                    <h4>Gérer les enseignants</h4>
                    <p>Disponibilités et matières</p>
                </div>
                <a href="/Enseignants" class="btn-icon-emit" style="margin-left:auto;" title="Enseignants">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

        </div>
    </section>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
    'use strict';

    /*  Helpers */
    function esc(s) { return window._emitEscapeHtml ? window._emitEscapeHtml(String(s ?? '')) : String(s ?? ''); }

    function getNiveauClass(niveau) {
        if (!niveau) return 'licence';
        const n = niveau.toLowerCase();
        if (n === 'master')   return 'master';
        if (n === 'doctorat') return 'doctorat';
        return 'licence';
    }

    function getNiveauIcon(niveau) {
        if (!niveau) return 'bi-bookmark';
        const n = niveau.toLowerCase();
        if (n === 'master')   return 'bi-bookmark-star-fill';
        if (n === 'doctorat') return 'bi-trophy-fill';
        return 'bi-bookmark-fill';
    }

    function formatTime() {
        return new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    }

    /* Construction du HTML d'une KPI card */
    function buildKpiCard(id, label, value, iconClass, iconTheme, trend, unit) {
        return `
        <div class="kpi-card animate-fadeinup stagger-${id}" role="article" aria-label="${esc(label)} : ${esc(value)}">
            <div class="kpi-label">${esc(label)}</div>
            <div class="kpi-value">${esc(value)}${unit ? `<span style="font-size:16px;font-weight:500;color:var(--text-muted);margin-left:2px;">${esc(unit)}</span>` : ''}</div>
            <div class="kpi-icon ${esc(iconTheme)}" aria-hidden="true"><i class="bi ${esc(iconClass)}"></i></div>
            <div class="kpi-trend"><i class="bi bi-arrow-up-short"></i>${esc(trend)}</div>
        </div>`;
    }

    /* ── Affichage KPIs ── */
    function renderKpis(kpis) {
        const grid = document.getElementById('kpi-grid');
        if (!grid) return;

        const cards = [
            buildKpiCard(1, 'Total Mentions',     kpis.totalMentions,     'bi-bookmark-fill',    'accent',   '+2 ce mois',   ''),
            buildKpiCard(2, 'Séances / semaine',  kpis.seancesSemaine,    'bi-calendar-event-fill','success', '+5 vs sem. passée', ''),
            buildKpiCard(3, 'Taux d\'occupation', kpis.tauxOccupation,    'bi-building-fill',    'warning',  '+3% vs moy.',  '%'),
            buildKpiCard(4, 'Heures enseignées',  kpis.heuresEnseignees,  'bi-clock-history',    'danger',   '+12h ce mois', 'h'),
        ];

        grid.innerHTML = cards.join('');
    }

    /* ── Affichage mentions récentes ── */
    function renderMentions(mentions) {
        const list    = document.getElementById('mentions-list');
        const skelEl  = document.getElementById('mentions-skeleton');
        if (!list) return;

        if (skelEl) skelEl.style.display = 'none';
        list.style.display = 'flex';

        if (!mentions || mentions.length === 0) {
            list.innerHTML = `
            <div class="empty-state" style="padding:24px 16px;">
                <i class="bi bi-inbox"></i>
                <h4>Aucune mention</h4>
                <p>Commencez par créer une mention.</p>
            </div>`;
            return;
        }

        const displayed = mentions.slice(0, 5);
        list.innerHTML = displayed.map(m => {
            const cls  = getNiveauClass(m.niveau);
            const icon = getNiveauIcon(m.niveau);
            return `
            <a href="/Mention/Edit?id=${esc(m.id)}" class="recent-item" role="listitem"
               title="Modifier ${esc(m.nom)}">
                <div class="recent-item-icon ${cls}" aria-hidden="true">
                    <i class="bi ${icon}"></i>
                </div>
                <div class="recent-item-info">
                    <div class="recent-item-nom">${esc(m.nom)}</div>
                    <div class="recent-item-niveau">${esc(m.niveau)}</div>
                </div>
                <i class="bi bi-chevron-right" style="color:var(--text-muted);font-size:12px;"></i>
            </a>`;
        }).join('');
    }

    /* ── Chart.js ── */
    let _chartInstance = null;

    function renderChart(seancesParJour) {
        const skelEl = document.getElementById('chart-skeleton');
        const wrapEl = document.getElementById('chart-wrap');
        const badge  = document.getElementById('chart-badge');
        const totalEl = document.getElementById('chart-total');
        const canvas  = document.getElementById('seancesChart');

        if (!canvas) return;

        if (skelEl) skelEl.style.display = 'none';
        if (wrapEl) wrapEl.style.display = 'block';

        const total = (seancesParJour.data || []).reduce((a, b) => a + b, 0);
        if (totalEl) totalEl.textContent = total;
        if (badge)   badge.style.display = 'inline-flex';

        /* Destruction de l'instance précédente si rafraîchi */
        if (_chartInstance) {
            _chartInstance.destroy();
            _chartInstance = null;
        }

        const ctx = canvas.getContext('2d');

        /* Gradient vertical */
        const grad = ctx.createLinearGradient(0, 0, 0, 220);
        grad.addColorStop(0,   'rgba(115,185,230,0.85)');
        grad.addColorStop(1,   'rgba(115,185,230,0.25)');

        _chartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: seancesParJour.labels,
                datasets: [{
                    label: 'Séances',
                    data: seancesParJour.data,
                    backgroundColor: grad,
                    hoverBackgroundColor: '#73B9E6',
                    borderRadius: 8,
                    borderSkipped: false,
                    barThickness: 'flex',
                    maxBarThickness: 52,
                }],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 700,
                    easing: 'easeOutQuart',
                },
                layout: { padding: { top: 8, bottom: 0, left: 0, right: 0 } },
                scales: {
                    x: {
                        grid:   { display: false, drawBorder: false },
                        border: { display: false },
                        ticks: {
                            color: '#94A3B8',
                            font: { family: "'DM Sans', sans-serif", size: 12, weight: '500' },
                        },
                    },
                    y: {
                        display: false,
                        grid:    { display: false },
                        border:  { display: false },
                        beginAtZero: true,
                    },
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#0F172A',
                        borderColor:     'rgba(115,185,230,0.3)',
                        borderWidth:     1,
                        titleColor:      '#F5F7FA',
                        bodyColor:       '#94A3B8',
                        titleFont:       { family: "'DM Sans', sans-serif", size: 13, weight: '600' },
                        bodyFont:        { family: "'DM Sans', sans-serif", size: 12 },
                        padding:         12,
                        cornerRadius:    8,
                        displayColors:   false,
                        callbacks: {
                            title: (items) => items[0]?.label || '',
                            label: (item)  => `  ${item.raw} séance${item.raw > 1 ? 's' : ''}`,
                        },
                    },
                },
            },
        });
    }

    /* ── Chargement principal ── */
    async function loadDashboard() {
        const updateTimeEl = document.getElementById('update-time');

        try {
            /* Chargements en parallèle */
            const [kpis, seancesParJour, mentions] = await Promise.all([
                window.MockAPI.getKPIs(),
                window.MockAPI.getSeancesParJour(),
                window.MockAPI.getMentions(),
            ]);

            renderKpis(kpis);
            renderChart(seancesParJour);
            renderMentions(mentions);

            if (updateTimeEl) updateTimeEl.textContent = formatTime();

        } catch (err) {
            window.handleApiError(err, 'Dashboard');

            /* Affichage d'un état d'erreur partiel */
            const grid = document.getElementById('kpi-grid');
            if (grid && grid.querySelector('.kpi-skeleton')) {
                grid.innerHTML = `
                <div style="grid-column:1/-1;padding:32px;text-align:center;color:var(--danger);">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size:32px;margin-bottom:10px;display:block;"></i>
                    <p style="font-size:14px;">Erreur de chargement. Cliquez sur <strong>Actualiser</strong> pour réessayer.</p>
                </div>`;
            }
        }
    }

    /* ── Bouton rafraîchir ── */
    function initRefreshBtn() {
        const btn = document.getElementById('btn-refresh');
        if (!btn) return;
        btn.addEventListener('click', () => {
            /* Reset skeletons KPI */
            const grid = document.getElementById('kpi-grid');
            if (grid) {
                grid.innerHTML = [1,2,3,4].map(i => `
                <div class="kpi-skeleton" id="kpi-skel-${i}">
                    <div class="skeleton skeleton-line w-55 h-10"></div>
                    <div class="skeleton skeleton-line w-30 h-32"></div>
                    <div class="skeleton skeleton-line w-40 h-10"></div>
                </div>`).join('');
            }
            /* Reset skeleton chart */
            const chartSkel = document.getElementById('chart-skeleton');
            const chartWrap = document.getElementById('chart-wrap');
            if (chartSkel) chartSkel.style.display = 'flex';
            if (chartWrap) chartWrap.style.display = 'none';

            /* Reset skeleton mentions */
            const mList = document.getElementById('mentions-list');
            const mSkel = document.getElementById('mentions-skeleton');
            if (mList)  mList.style.display = 'none';
            if (mSkel)  mSkel.style.display = 'flex';

            window.fetchWithSpinner(btn, loadDashboard());
        });
    }

    /* ── Init ── */
    document.addEventListener('DOMContentLoaded', () => {
        loadDashboard();
        initRefreshBtn();
    });

})();
</script>
}