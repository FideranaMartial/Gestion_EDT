@model Gestion_EDT.Models.Mention
@{
    ViewData["Title"] = "Nouvelle Mention";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-plus-circle-fill"></i></div>
            <div>
                <div class="form-card-title">Créer une nouvelle mention</div>
                <div class="form-card-sub">Renseignez les informations</div>
            </div>
        </div>
        <div class="form-card-body">
            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()
                <div class="form-group mb-3">
                    <label asp-for="nom_mention" class="form-label">Nom de la mention *</label>
                    <input asp-for="nom_mention" class="form-control" required />
                    <span asp-validation-for="nom_mention" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="code_mention" class="form-label">Code mention *</label>
                    <input asp-for="code_mention" class="form-control" required maxlength="10" />
                    <span asp-validation-for="code_mention" class="text-danger"></span>
                </div>
                <div class="form-footer">
                    <button type="submit" class="btn-primary-emit"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.form-card { background: linear-gradient(145deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%); border: 1px solid rgba(115,185,230,0.12); border-radius: var(--radius); overflow: hidden; }
.form-card-header { padding: 22px 28px; border-bottom: 1px solid rgba(115,185,230,0.1); display: flex; align-items: center; gap: 14px; }
.form-card-icon { width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, rgba(115,185,230,0.2), rgba(115,185,230,0.08)); border: 1px solid rgba(115,185,230,0.2); display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--accent); }
.form-card-title { font-size: 16px; font-weight: 600; margin-bottom: 2px; }
.form-card-sub { font-size: 12px; color: var(--text-muted); }
.form-card-body { padding: 28px; }
.form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.2rem; }
.form-label { font-size: 14px; font-weight: 600; color: var(--text-primary); }
.form-control { padding: 10px 12px; background: rgba(23,37,84,0.3); border: 1px solid rgba(115,185,230,0.2); border-radius: 8px; color: var(--text-primary); transition: 0.2s; width: 100%; }
.form-control:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(115,185,230,0.1); background: rgba(23,37,84,0.5); outline: none; }
.form-footer { display: flex; gap: 12px; padding-top: 8px; border-top: 1px solid rgba(115,185,230,0.08); margin-top: 20px; }
.text-danger { color: #ef4444; font-size: 12px; margin-top: 4px; }
</style>