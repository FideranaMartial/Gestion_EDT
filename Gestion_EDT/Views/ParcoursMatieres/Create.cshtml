@{
    ViewData["Title"] = "Nouvelle affectation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-link-45deg"></i></div>
            <div>
                <div class="form-card-title">Affecter une matière à un parcours</div>
                <div class="form-card-sub">Sélectionnez un parcours et une matière</div>
            </div>
        </div>
        <div class="form-card-body">
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div class="form-group mb-3">
                    <label class="form-label" for="parcoursId">Parcours *</label>
                    <select id="parcoursId" class="form-control" asp-items="ViewBag.ParcoursId" required>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label" for="matiereId">Matière *</label>
                    <select id="matiereId" class="form-control" asp-items="ViewBag.MatiereId" required>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn-primary-emit" id="btnSubmit"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSubmit').addEventListener('click', function() {
            const parcoursId = parseInt(document.getElementById('parcoursId').value);
            const matiereId = parseInt(document.getElementById('matiereId').value);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!parcoursId || !matiereId) {
                window.showToast('Veuillez sélectionner un parcours et une matière.', 'warning');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('parcoursId', parcoursId);
            formData.append('matiereId', matiereId);

            fetch('/ParcoursMatieres/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(async r => {
                if (r.ok) {
                    window.showToast('Association créée avec succès.', 'success');
                    setTimeout(() => window.location.href = '/ParcoursMatieres', 800);
                } else {
                    try {
                        const data = await r.json();
                        if (data.errors) {
                            window.showToast(data.errors.join('\n'), 'error');
                        } else {
                            window.showToast('Erreur lors de la création.', 'error');
                        }
                    } catch {
                        window.showToast('Erreur inconnue.', 'error');
                    }
                }
            })
            .catch(err => window.showToast('Erreur réseau.', 'error'));
        });
    </script>
}