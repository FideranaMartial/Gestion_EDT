@{
    ViewData["Title"] = "Planning";
    ViewData["ActivePage"] = "Planning";
}

<div class="planning-page">

    <!-- ══════════════════════════════════════════════
         En-tête de page
    ═══════════════════════════════════════════════ -->
    <div class="page-header-emit">
        <div class="page-header-left">
            <div class="page-icon-wrap">
                <i class="bi bi-calendar3-week-fill"></i>
            </div>
            <div>
                <h1 class="page-title-emit">Planning</h1>
                <p class="page-subtitle-emit">Visualisez l'emploi du temps par mention, parcours et groupe</p>
            </div>
        </div>
        <div class="page-header-actions">
            <button id="btnNewSeance" class="btn-emit-primary">
                <i class="bi bi-plus-lg me-2"></i>Nouvelle séance
            </button>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════
         Filtres en cascade
    ═══════════════════════════════════════════════ -->
    <div class="card-emit filter-card mb-4">
        <div class="filter-card-header">
            <i class="bi bi-funnel-fill me-2" style="color: var(--accent);"></i>
            <span>Filtrer l'affichage</span>
        </div>
        <div class="filter-grid">

            <!-- Mention -->
            <div class="filter-group">
                <label class="filter-label" for="filterMention">
                    <i class="bi bi-bookmark-fill me-1"></i>Mention
                </label>
                <div class="select-wrapper">
                    <select id="filterMention" class="emit-select">
                        <option value="">Toutes les mentions</option>
                    </select>
                    <i class="bi bi-chevron-down select-arrow"></i>
                </div>
            </div>

            <!-- Parcours -->
            <div class="filter-group">
                <label class="filter-label" for="filterParcours">
                    <i class="bi bi-diagram-3-fill me-1"></i>Parcours
                </label>
                <div class="select-wrapper">
                    <select id="filterParcours" class="emit-select" disabled>
                        <option value="">Tous les parcours</option>
                    </select>
                    <i class="bi bi-chevron-down select-arrow"></i>
                </div>
                <span class="filter-hint" id="hintParcours">Sélectionnez une mention</span>
            </div>

            <!-- Groupe -->
            <div class="filter-group">
                <label class="filter-label" for="filterGroupe">
                    <i class="bi bi-people-fill me-1"></i>Groupe
                </label>
                <div class="select-wrapper">
                    <select id="filterGroupe" class="emit-select" disabled>
                        <option value="">Tous les groupes</option>
                    </select>
                    <i class="bi bi-chevron-down select-arrow"></i>
                </div>
                <span class="filter-hint" id="hintGroupe">Sélectionnez un parcours</span>
            </div>

        </div>
    </div>

    <!-- ══════════════════════════════════════════════
         Légende rapide
    ═══════════════════════════════════════════════ -->
    <div class="calendar-legend mb-3">
        <div class="legend-item">
            <span class="legend-dot" style="background:#73B9E6;"></span>
            <span>Cours magistral</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background:#34D399;"></span>
            <span>TD</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background:#FBBF24;"></span>
            <span>TP</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background:#F87171;"></span>
            <span>Examen</span>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════
         Calendrier
    ═══════════════════════════════════════════════ -->
    <div class="card-emit calendar-card">
        <div id="calendar"></div>
    </div>

</div>

<!-- Styles spécifiques à la vue Planning -->
<style>
    /* ── Page layout ── */
    .planning-page {
        padding: 1.5rem;
    }

    /* ── En-tête ── */
    .page-header-emit {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }
    .page-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .page-icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: var(--radius);
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--bg-primary);
        box-shadow: 0 4px 12px rgba(115,185,230,0.35);
        flex-shrink: 0;
    }
    .page-title-emit {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
        line-height: 1.2;
    }
    .page-subtitle-emit {
        font-size: 0.83rem;
        color: var(--text-muted);
        margin: 0;
        margin-top: 2px;
    }

    /* ── Carte filtres ── */
    .filter-card {
        padding: 1.25rem 1.5rem;
    }
    .filter-card-header {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
    }
    .filter-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem 1.5rem;
    }
    @@media (max-width: 768px) {
        .filter-grid { grid-template-columns: 1fr; }
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .filter-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .select-wrapper {
        position: relative;
    }
    .emit-select {
        width: 100%;
        background: rgba(23,37,84,0.6);
        border: 1px solid rgba(115,185,230,0.2);
        border-radius: 8px;
        color: var(--text-primary);
        font-family: var(--font-main);
        font-size: 0.88rem;
        padding: 0.55rem 2.2rem 0.55rem 0.8rem;
        appearance: none;
        -webkit-appearance: none;
        cursor: pointer;
        transition: var(--transition);
        outline: none;
    }
    .emit-select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(115,185,230,0.15);
    }
    .emit-select:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
    .emit-select option {
        background: #1F4E79;
        color: var(--text-primary);
    }
    .select-arrow {
        position: absolute;
        right: 0.7rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.75rem;
        pointer-events: none;
    }
    .filter-hint {
        font-size: 0.73rem;
        color: var(--text-muted);
        font-style: italic;
        min-height: 1em;
    }

    /* ── Légende ── */
    .calendar-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        padding: 0 0.25rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ── Carte calendrier ── */
    .calendar-card {
        padding: 1.25rem;
        min-height: 600px;
    }

    /* ── Responsive header actions ── */
    @@media (max-width: 576px) {
        .page-header-emit { flex-direction: column; align-items: flex-start; }
        .page-header-actions { width: 100%; }
        .page-header-actions .btn-emit-primary { width: 100%; justify-content: center; }
    }
</style>

@section Scripts {
    <!-- FullCalendar v6.1.10 via CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@fullcalendar/core@6.1.10/locales/fr.global.min.js"></script>
    <script src="~/js/timetable.js"></script>

    <script>
        /* Met à jour les hints des selects en cascade */
        document.addEventListener('DOMContentLoaded', function () {
            const mentionSel = document.getElementById('filterMention');
            const parcoursSel = document.getElementById('filterParcours');
            const hintParcours = document.getElementById('hintParcours');
            const hintGroupe = document.getElementById('hintGroupe');

            mentionSel.addEventListener('change', function () {
                if (this.value) {
                    hintParcours.textContent = '';
                } else {
                    hintParcours.textContent = 'Sélectionnez une mention';
                }
                hintGroupe.textContent = 'Sélectionnez un parcours';
            });

            parcoursSel.addEventListener('change', function () {
                if (this.value) {
                    hintGroupe.textContent = '';
                } else {
                    hintGroupe.textContent = 'Sélectionnez un parcours';
                }
            });
        });
    </script>
}
