@{
    ViewData["Title"] = "Planning";
    ViewData["ActivePage"] = "Planning";
}

<div class="planning-page">

    <!-- En-tête -->
    <div class="page-header-emit">
        <div class="page-header-left">
            <div class="page-icon-wrap">
                <i class="bi bi-calendar3-week-fill"></i>
            </div>
            <div>
                <h1 class="page-title-emit">Planning</h1>
                <p class="page-subtitle-emit">Visualisez l'emploi du temps par mention, parcours et groupe</p>
            </div>
        </div>
        <div class="page-header-actions">
            <!-- Correction du lien : /Seances/Create au lieu de /Seance/Create -->
            <a id="btnNewSeance" href="/Seances/Create" class="btn-emit-primary">
                <i class="bi bi-plus-lg me-2"></i>Nouvelle séance
            </a>
        </div>
    </div>

    <!-- Filtres en cascade -->
    <div class="card-emit filter-card mb-4">
        <div class="filter-card-header">
            <i class="bi bi-funnel-fill me-2" style="color: var(--accent);"></i>
            <span>Filtrer l'affichage</span>
        </div>
        <div class="filter-grid">
            <div class="filter-group">
                <label class="filter-label" for="filterMention">Mention</label>
                <select id="filterMention" class="emit-select">
                    <option value="">Toutes les mentions</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label" for="filterParcours">Parcours</label>
                <select id="filterParcours" class="emit-select" disabled>
                    <option value="">Tous les parcours</option>
                </select>
                <span class="filter-hint" id="hintParcours">Sélectionnez une mention</span>
            </div>
            <div class="filter-group">
                <label class="filter-label" for="filterGroupe">Groupe</label>
                <select id="filterGroupe" class="emit-select" disabled>
                    <option value="">Tous les groupes</option>
                </select>
                <span class="filter-hint" id="hintGroupe">Sélectionnez un parcours</span>
            </div>
        </div>
    </div>

    <!-- Légende -->
    <div class="calendar-legend mb-3">
        <div class="legend-item"><span class="legend-dot" style="background:#73B9E6;"></span><span>Cours magistral</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#34D399;"></span><span>TD</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#FBBF24;"></span><span>TP</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#F87171;"></span><span>Examen</span></div>
    </div>

    <!-- Calendrier -->
    <div class="card-emit calendar-card">
        <div id="calendar"></div>
    </div>
</div>

<style>
    /* ===== Styles déjà présents dans votre fichier (inchangés) ===== */
    .planning-page { padding: 1.5rem; }
    .page-header-emit { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.75rem; }
    .page-header-left { display: flex; align-items: center; gap: 1rem; }
    .page-icon-wrap { width: 52px; height: 52px; border-radius: var(--radius); background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--bg-primary); box-shadow: 0 4px 12px rgba(115,185,230,0.35); flex-shrink: 0; }
    .page-title-emit { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2; }
    .page-subtitle-emit { font-size: 0.83rem; color: var(--text-muted); margin-top: 2px; }
    .filter-card { padding: 1.25rem 1.5rem; }
    .filter-card-header { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1rem; display: flex; align-items: center; }
    .filter-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem 1.5rem; }
    @@media (max-width: 768px) { .filter-grid { grid-template-columns: 1fr; } }
    .filter-group { display: flex; flex-direction: column; gap: 6px; }
    .filter-label { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .select-wrapper { position: relative; }
    .emit-select { width: 100%; background: rgba(23,37,84,0.6); border: 1px solid rgba(115,185,230,0.2); border-radius: 8px; color: var(--text-primary); font-family: var(--font-main); font-size: 0.88rem; padding: 0.55rem 2.2rem 0.55rem 0.8rem; appearance: none; cursor: pointer; transition: var(--transition); outline: none; }
    .emit-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(115,185,230,0.15); }
    .emit-select:disabled { opacity: 0.4; cursor: not-allowed; }
    .emit-select option { background: #1F4E79; color: var(--text-primary); }
    .filter-hint { font-size: 0.73rem; color: var(--text-muted); font-style: italic; min-height: 1em; }
    .calendar-legend { display: flex; flex-wrap: wrap; gap: 0.75rem 1.5rem; padding: 0 0.25rem; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; color: var(--text-muted); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .calendar-card { padding: 1.25rem; min-height: 600px; }
    @@media (max-width: 576px) {
        .page-header-emit { flex-direction: column; align-items: flex-start; }
        .page-header-actions { width: 100%; }
        .page-header-actions .btn-emit-primary { width: 100%; justify-content: center; }
    }
</style>

@section Scripts {
    <!-- FullCalendar CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@fullcalendar/core@6.1.10/locales/fr.global.min.js"></script>

    <script>
        (function() {
            'use strict';

            const mentionSelect = document.getElementById('filterMention');
            const parcoursSelect = document.getElementById('filterParcours');
            const groupeSelect = document.getElementById('filterGroupe');
            const hintParcours = document.getElementById('hintParcours');
            const hintGroupe = document.getElementById('hintGroupe');
            let calendar = null;

            async function loadMentions() {
                try {
                    const response = await fetch('/Mentions/GetMentionsJson');
                    if (!response.ok) throw new Error('Erreur chargement mentions');
                    const mentions = await response.json();
                    mentionSelect.innerHTML = '<option value="">Toutes les mentions</option>';
                    mentions.forEach(m => {
                        const option = document.createElement('option');
                        option.value = m.id;
                        option.textContent = m.nom || m.Nom;
                        mentionSelect.appendChild(option);
                    });
                } catch (err) {
                    console.error(err);
                    window.showToast('Erreur chargement mentions', 'error');
                }
            }

            async function loadParcours(mentionId) {
                parcoursSelect.disabled = !mentionId;
                parcoursSelect.innerHTML = '<option value="">Tous les parcours</option>';
                groupeSelect.disabled = true;
                groupeSelect.innerHTML = '<option value="">Tous les groupes</option>';
                hintGroupe.textContent = 'Sélectionnez un parcours';

                if (!mentionId) {
                    hintParcours.textContent = 'Sélectionnez une mention';
                    if (calendar) calendar.refetchEvents();
                    return;
                }
                hintParcours.textContent = '';
                try {
                    const response = await fetch(`/Planning/GetParcours?mentionId=${mentionId}`);
                    if (!response.ok) throw new Error('Erreur chargement parcours');
                    const parcours = await response.json();
                    parcours.forEach(p => {
                        const option = document.createElement('option');
                        option.value = p.value;
                        option.textContent = p.label;
                        parcoursSelect.appendChild(option);
                    });
                    parcoursSelect.disabled = false;
                } catch (err) {
                    window.showToast('Impossible de charger les parcours', 'error');
                    console.error(err);
                }
                if (calendar) calendar.refetchEvents();
            }

            async function loadGroupes(parcoursId) {
                groupeSelect.disabled = !parcoursId;
                groupeSelect.innerHTML = '<option value="">Tous les groupes</option>';
                if (!parcoursId) {
                    hintGroupe.textContent = 'Sélectionnez un parcours';
                    if (calendar) calendar.refetchEvents();
                    return;
                }
                hintGroupe.textContent = '';
                try {
                    const response = await fetch(`/Planning/GetGroupes?parcoursId=${parcoursId}`);
                    if (!response.ok) throw new Error('Erreur chargement groupes');
                    const groupes = await response.json();
                    groupes.forEach(g => {
                        const option = document.createElement('option');
                        option.value = g.value;
                        option.textContent = g.label;
                        groupeSelect.appendChild(option);
                    });
                    groupeSelect.disabled = false;
                } catch (err) {
                    console.error(err);
                }
                if (calendar) calendar.refetchEvents();
            }

            function initCalendar() {
                const calendarEl = document.getElementById('calendar');
                if (!calendarEl) return;
                calendar = new FullCalendar.Calendar(calendarEl, {
                    locale: 'fr',
                    initialView: 'timeGridWeek',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'timeGridWeek,timeGridDay'
                    },
                    slotMinTime: '07:30:00',
                    slotMaxTime: '18:30:00',
                    hiddenDays: [0],
                    events: async function(fetchInfo, successCallback, failureCallback) {
                        const groupeId = groupeSelect.value;
                        if (!groupeId) {
                            successCallback([]);
                            return;
                        }
                        try {
                            // Utiliser l'action existante de SeancesController ou PlanningController
                            // On suppose que /Seances/GetSeancesJson?groupeId=... existe
                            // Pour l'instant on utilise un fetch vers une API (à adapter)
                            const response = await fetch(`/Seances/GetSeancesJson?groupeId=${groupeId}`);
                            if (!response.ok) throw new Error('Erreur chargement séances');
                            const seances = await response.json();
                            const events = seances.map(s => ({
                                id: s.id,
                                title: s.title,
                                start: s.start,
                                end: s.end,
                                extendedProps: { salle: s.salle, professeur: s.professeur }
                            }));
                            successCallback(events);
                        } catch (err) {
                            console.error(err);
                            failureCallback(err);
                        }
                    },
                    eventClick: function(info) {
                        alert(`${info.event.title}\nSalle : ${info.event.extendedProps.salle}\nEnseignant : ${info.event.extendedProps.professeur}`);
                    }
                });
                calendar.render();
            }

            function bindEvents() {
                mentionSelect.addEventListener('change', () => loadParcours(mentionSelect.value));
                parcoursSelect.addEventListener('change', () => loadGroupes(parcoursSelect.value));
                groupeSelect.addEventListener('change', () => { if (calendar) calendar.refetchEvents(); });
            }

            document.addEventListener('DOMContentLoaded', async () => {
                await loadMentions();
                initCalendar();
                bindEvents();
            });
        })();
    </script>
}