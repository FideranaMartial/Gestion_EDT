@model Gestion_EDT.Models.Matiere
@{
    ViewData["Title"] = "Nouvelle Matière";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width:600px;margin-top:2rem;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div>
                <div class="form-card-title">Créer une nouvelle matière</div>
                <div class="form-card-sub">Renseignez les informations de la matière</div>
            </div>
        </div>
        <div class="form-card-body">
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>
                <div class="form-group mb-3">
                    <label asp-for="code_mat" class="form-label">Code *</label>
                    <input asp-for="code_mat" class="form-control" id="code_mat" required />
                    <span asp-validation-for="code_mat" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="intitule" class="form-label">Intitulé *</label>
                    <input asp-for="intitule" class="form-control" id="intitule" required />
                    <span asp-validation-for="intitule" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="nb_heure" class="form-label">Nombre d'heures *</label>
                    <input asp-for="nb_heure" type="number" class="form-control" id="nb_heure" required />
                    <span asp-validation-for="nb_heure" class="text-danger"></span>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn-primary-emit" id="btnSubmit"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn-secondary-emit">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSubmit').addEventListener('click', function() {
            const code = document.getElementById('code_mat').value.trim();
            const intitule = document.getElementById('intitule').value.trim();
            const nbHeure = parseInt(document.getElementById('nb_heure').value);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!code || !intitule || !nbHeure) {
                window.showToast('Tous les champs sont obligatoires.', 'warning');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('code_mat', code);
            formData.append('intitule', intitule);
            formData.append('nb_heure', nbHeure);

            fetch('/Matieres/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            })
            .then(async r => {
                if (r.ok) {
                    window.showToast('Matière créée avec succès.', 'success');
                    setTimeout(() => window.location.href = '/Matieres', 800);
                } else {
                    try {
                        const data = await r.json();
                        if (data.errors) {
                            window.showToast(data.errors.join('\n'), 'error');
                        } else {
                            window.showToast('Erreur lors de la création.', 'error');
                        }
                    } catch {
                        window.showToast('Erreur inconnue.', 'error');
                    }
                }
            })
            .catch(err => window.showToast('Erreur réseau.', 'error'));
        });
    </script>
}