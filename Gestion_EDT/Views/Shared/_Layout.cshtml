@* ═══════════════════════════════════════
   FICHIER : /Views/Shared/_Layout.cshtml
   Application : EMIT — Gestion Emploi du Temps
   ═══════════════════════════════════════ *@
@using System.Security.Claims
<!DOCTYPE html>
<html lang="fr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EMIT — Application de gestion des emplois du temps universitaires" />
    <title>@ViewData["Title"] – EMIT</title>

    @* ─── DM Sans — Google Fonts ─── *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

    @* ─── Bootstrap Icons 1.11 ─── *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    @* ─── EMIT Site CSS ─── *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* ─── Styles spécifiques à la vue ─── *@
    @await RenderSectionAsync("Styles", required: false)

    @* ─── Token CSRF caché (accessible globalement via window.getAntiForgeryToken()) ─── *@
    @Html.AntiForgeryToken()
</head>
<body>

    @* ═════════════════════════════════════════
       OVERLAY SIDEBAR MOBILE
       ═════════════════════════════════════════ *@
    <div id="sidebar-overlay" class="sidebar-overlay" aria-hidden="true"></div>

    @* ═════════════════════════════════════════
       WRAPPER PRINCIPAL (CSS GRID)
       ═════════════════════════════════════════ *@
    <div id="app-wrapper">

        @* ══════════════════════════════════════
           SIDEBAR — 260px (70px collapsed)
           ══════════════════════════════════════ *@
        <nav id="sidebar" role="navigation" aria-label="Navigation principale">

            @* ─── Brand / Logo ─── *@
            <a class="sidebar-brand" href="/" aria-label="Accueil EMIT">
                <div class="sidebar-brand-icon" aria-hidden="true">
                    <i class="bi bi-calendar3-week"></i>
                </div>
                <div class="sidebar-brand-text">
                    <span class="sidebar-brand-name">EMIT</span>
                    <span class="sidebar-brand-sub">Emploi du Temps</span>
                </div>
            </a>

            @* ─── Navigation ─── *@
            <div class="sidebar-nav" role="list">

                <div class="sidebar-section-label">Principal</div>

                <a class="nav-link"
                   href="/Home"
                   data-path="/home"
                   role="listitem"
                   title="Tableau de bord">
                    <i class="bi bi-grid-1x2-fill" aria-hidden="true"></i>
                    <span class="nav-link-label">Dashboard</span>
                </a>

                <a class="nav-link"
                   href="/Mentions"
                   data-path="/mentions"
                   role="listitem"
                   title="Gestion des mentions">
                    <i class="bi bi-mortarboard-fill" aria-hidden="true"></i>
                    <span class="nav-link-label">Mentions</span>
                </a>

                <a class="nav-link"
                   href="/Seances"
                   data-path="/seances"
                   role="listitem"
                   title="Gestion des séances">
                    <i class="bi bi-journal-bookmark-fill" aria-hidden="true"></i>
                    <span class="nav-link-label">Séances</span>
                </a>

                <div class="sidebar-section-label">Planning</div>

                <a class="nav-link"
                   href="/Planning"
                   data-path="/planning"
                   role="listitem"
                   title="Calendrier des emplois du temps">
                    <i class="bi bi-calendar-week-fill" aria-hidden="true"></i>
                    <span class="nav-link-label">Planning</span>
                </a>

                <a class="nav-link"
                   href="/Enseignants"
                   data-path="/enseignants"
                   role="listitem"
                   title="Gestion des enseignants">
                    <i class="bi bi-people-fill" aria-hidden="true"></i>
                    <span class="nav-link-label">Enseignants</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section-label">Administration</div>
                    <a class="nav-link"
                       href="/Account/Index"
                       data-path="/account"
                       role="listitem"
                       title="Gestion des comptes">
                        <i class="bi bi-shield-lock-fill" aria-hidden="true"></i>
                        <span class="nav-link-label">Comptes</span>
                    </a>
                }

            </div>

            @* ─── Footer utilisateur ─── *@
            <div class="sidebar-footer">
                @{
                    var userNomComplet = User.FindFirst("NomComplet")?.Value ?? User.Identity?.Name ?? "Utilisateur";
                    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "Enseignant";
                    var userInitiales = GetInitiales(userNomComplet);
                    var userRoleLabel = userRole switch
                    {
                        "Admin" => "Administrateur",
                        "RespEDT" => "Resp. EDT",
                        _ => "Enseignant"
                    };
                }
                <div class="sidebar-footer-user" title="@userNomComplet — @userRoleLabel">
                    <div class="sidebar-avatar" aria-hidden="true">@userInitiales</div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">@userNomComplet</div>
                        <div class="sidebar-user-role">@userRoleLabel</div>
                    </div>
                </div>
            </div>

        </nav>
        @* fin #sidebar *@


        @* ══════════════════════════════════════
           TOPBAR — 64px
           ══════════════════════════════════════ *@
        <header id="topbar" role="banner">

            <div class="topbar-left">
                @* Bouton toggle sidebar *@
                <button id="sidebar-toggle-btn"
                        type="button"
                        aria-label="Basculer la barre latérale"
                        aria-expanded="true"
                        aria-controls="sidebar"
                        title="Réduire / agrandir la barre latérale">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>

                @* Titre de la page courante *@
                <div class="topbar-breadcrumb">
                    <span id="topbar-page-title" class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
                </div>
            </div>

            <div class="topbar-right">

                @* Informations utilisateur *@
                <div class="topbar-user" aria-label="Utilisateur connecté">
                    <div>
                        <div class="topbar-user-name">@userNomComplet</div>
                        <div class="topbar-user-role">@userRoleLabel</div>
                    </div>
                    <div class="topbar-avatar" aria-hidden="true">@userInitiales</div>
                </div>

                @* Bouton déconnexion *@
                <form asp-controller="Account" asp-action="Logout" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout"
                            title="Se déconnecter"
                            aria-label="Se déconnecter de l'application">
                        <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        <span>Déconnexion</span>
                    </button>
                </form>

            </div>

        </header>
        @* fin #topbar *@


        @* ══════════════════════════════════════
           CONTENU PRINCIPAL
           ══════════════════════════════════════ *@
        <main id="main-content" role="main" aria-label="Contenu principal">
            @RenderBody()
        </main>
        @* fin #main-content *@

    </div>
    @* fin #app-wrapper *@


    @* ═════════════════════════════════════════
       TOAST CONTAINER
       ═════════════════════════════════════════ *@
    <div id="toast-container"
         role="region"
         aria-label="Notifications"
         aria-live="polite"
         aria-atomic="false">
    </div>


    @* ═════════════════════════════════════════
       CONFIRM MODAL (Bootstrap 5)
       ═════════════════════════════════════════ *@
    <div id="confirmModal"
         class="modal fade modal-emit"
         tabindex="-1"
         role="dialog"
         aria-labelledby="confirmModalTitle"
         aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmModalTitle">
                        <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning);margin-right:8px;"></i>
                        Confirmation
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"
                            aria-label="Fermer la fenêtre de confirmation"></button>
                </div>
                <div class="modal-body" id="confirmModalBody">
                    Êtes-vous sûr de vouloir effectuer cette action ?
                </div>
                <div class="modal-footer">
                    <button type="button"
                            id="cancelModalBtn"
                            class="btn-secondary-emit"
                            data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i>
                        Annuler
                    </button>
                    <button type="button"
                            id="confirmModalBtn"
                            class="btn-danger-emit">
                        <i class="bi bi-check-lg"></i>
                        Confirmer
                    </button>
                </div>
            </div>
        </div>
    </div>
    @* fin #confirmModal *@


    @* ═════════════════════════════════════════
       SCRIPTS — Ordre obligatoire
       ═════════════════════════════════════════ *@

    @* 1. Bootstrap 5.3 Bundle (Popper inclus) *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @* 2. API centralisée *@
    <script src="~/js/api.js" asp-append-version="true"></script>

    @* 3. Moteur de validation *@
    <script src="~/js/validation.js" asp-append-version="true"></script>

    @* 4. Fonctions globales site *@
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* 5. Scripts spécifiques à la vue *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

@functions {
    // Fonction pour générer les initiales à partir du nom complet
    public static string GetInitiales(string nomComplet)
    {
        if (string.IsNullOrWhiteSpace(nomComplet)) return "?";

        var parts = nomComplet.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        }

        var initiales = parts[0][0].ToString() + parts[^1][0].ToString();
        return initiales.ToUpper();
    }
}